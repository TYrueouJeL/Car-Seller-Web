<div class="bg-slate-900 border border-white/8 rounded-2xl p-6 flex flex-col md:flex-row gap-6 hover:border-emerald-500/30 transition-all duration-300">
  <div class="flex-1 grid grid-cols-2 gap-x-6 gap-y-3">
    <h2 class="col-span-2 text-white font-bold text-lg mb-1">{{ maintenance.type.name }}</h2>

    <div>
      <p class="text-white/35 text-xs uppercase tracking-wider mb-0.5">Client</p>
      <p class="text-white/80 text-sm font-medium">{{ maintenance.customer.lastname }} {{ maintenance.customer.firstname }}</p>
    </div>
    <div>
      <p class="text-white/35 text-xs uppercase tracking-wider mb-0.5">Technicien</p>
      <p class="text-white/80 text-sm font-medium">{{ maintenance.technician.lastname }} {{ maintenance.technician.firstname }}</p>
    </div>
    <div>
      <p class="text-white/35 text-xs uppercase tracking-wider mb-0.5">Statut</p>
      <span class="inline-block text-xs font-semibold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-2.5 py-0.5 rounded-full">{{ maintenance.maintenanceStatus.name }}</span>
    </div>
    <div>
      <p class="text-white/35 text-xs uppercase tracking-wider mb-0.5">Type</p>
      <p class="text-white/80 text-sm">{{ maintenance.type.name }}</p>
    </div>
    <div>
      <p class="text-white/35 text-xs uppercase tracking-wider mb-0.5">Date</p>
      <p class="text-white/80 text-sm">{{ maintenance.date|date("d/m/Y H:i") }}</p>
    </div>
    <div>
      <p class="text-white/35 text-xs uppercase tracking-wider mb-0.5">Durée</p>
      <p class="text-white/80 text-sm">{{ maintenance.type.duration }} min</p>
    </div>
  </div>

  <div class="md:w-56 shrink-0">
    {{ component('vehicle_card', {
      'vehicle': maintenance.vehicle,
      'detail_path': 'vehicle/userVehicle/' ~ maintenance.vehicle.id,
      'type': 'userVehicle',
    }) }}
  </div>
</div>