<div class="bg-slate-900 border border-white/8 rounded-2xl p-6 flex flex-col md:flex-row gap-6 hover:border-blue-500/30 transition-all duration-300">
  <div class="flex-1 grid grid-cols-2 gap-x-6 gap-y-3">
    <h2 class="col-span-2 text-white font-bold text-lg mb-1">{{ maintenanceRequest.type.name }}</h2>

    <div>
      <p class="text-white/35 text-xs uppercase tracking-wider mb-0.5">Client</p>
      <p class="text-white/80 text-sm font-medium">{{ maintenanceRequest.customer.lastname }} {{ maintenanceRequest.customer.firstname }}</p>
    </div>
    <div>
      <p class="text-white/35 text-xs uppercase tracking-wider mb-0.5">Type</p>
      <p class="text-white/80 text-sm">{{ maintenanceRequest.type.name }}</p>
    </div>
    <div>
      <p class="text-white/35 text-xs uppercase tracking-wider mb-0.5">Date demandée</p>
      <p class="text-white/80 text-sm">{{ maintenanceRequest.requestDate|date("d/m/Y H:i") }}</p>
    </div>
    <div>
      <p class="text-white/35 text-xs uppercase tracking-wider mb-0.5">Durée</p>
      <p class="text-white/80 text-sm">{{ maintenanceRequest.type.duration }} min</p>
    </div>
  </div>

  <div class="md:w-56 shrink-0">
    {{ component('vehicle_card', {
      'vehicle': maintenanceRequest.vehicle,
      'detail_path': 'vehicle/userVehicle/' ~ maintenanceRequest.vehicle.id,
      'type': 'userVehicle',
    }) }}
  </div>
</div>