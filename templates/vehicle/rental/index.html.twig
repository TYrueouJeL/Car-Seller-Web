{% extends 'base.html.twig' %}
{% block title %}Locations{% endblock %}
{% block body %}
<div class="min-h-[calc(100vh-64px)] bg-slate-950 px-6 py-14 relative">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_40%_at_50%_0%,rgba(37,99,235,0.12),transparent)] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto relative">
    <div class="text-center mb-12">
      <p class="text-blue-400 text-xs font-semibold tracking-widest uppercase mb-3">Catalogue</p>
      <h1 class="text-4xl md:text-5xl font-black text-white tracking-tight">Locations</h1>
    </div>

    <div class="flex justify-center mb-10">
      {{ knp_pagination_render(vehicles) }}
    </div>

    {{ component('card_list', {
      'items': vehicles|slice(0, vehicles|length),
      'type': 'rental',
    }) }}
  </div>
</div>
{% endblock %}