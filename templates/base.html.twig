<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}CarSeller{% endblock %}</title>

  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⬡</text></svg>">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

  {% block stylesheets %}
    {{ encore_entry_link_tags('app') }}
  {% endblock %}

  <style>
    html { scroll-behavior: smooth; }
    body { font-family: 'DM Sans', sans-serif; background-color: #020817; }

    /* Flatpickr dark override */
    .flatpickr-calendar {
      background: #0f172a !important;
      border: 1px solid rgba(255,255,255,0.08) !important;
      border-radius: 12px !important;
      box-shadow: 0 16px 48px rgba(0,0,0,0.5) !important;
    }
    .flatpickr-day { color: rgba(255,255,255,0.6) !important; border-radius: 8px !important; }
    .flatpickr-day:hover { background: rgba(255,255,255,0.08) !important; color: white !important; }
    .flatpickr-day.selected, .flatpickr-day.startRange, .flatpickr-day.endRange {
      background: #2563eb !important; border-color: #2563eb !important; color: white !important;
    }
    .flatpickr-day.inRange {
      background: rgba(37,99,235,0.2) !important;
      border-color: transparent !important;
      box-shadow: none !important;
      color: white !important;
    }
    .flatpickr-day.disabled { color: rgba(255,255,255,0.15) !important; }
    .flatpickr-months, .flatpickr-weekdays { background: transparent !important; }
    .flatpickr-current-month, .flatpickr-monthDropdown-months { color: white !important; }
    .flatpickr-prev-month svg, .flatpickr-next-month svg { fill: rgba(255,255,255,0.4) !important; }
    .flatpickr-weekday { color: rgba(255,255,255,0.25) !important; }
    span.flatpickr-weekday { background: transparent !important; }
    .flatpickr-months .flatpickr-prev-month:hover svg,
    .flatpickr-months .flatpickr-next-month:hover svg { fill: white !important; }

    /* KNP Pagination dark override */
    .pagination { display: flex; align-items: center; gap: 6px; list-style: none; padding: 0; margin: 0; }
    .pagination li a, .pagination li span {
      display: flex; align-items: center; justify-content: center;
      width: 36px; height: 36px; border-radius: 8px;
      background: #0f172a; border: 1px solid rgba(255,255,255,0.08);
      color: rgba(255,255,255,0.5); font-size: 0.875rem;
      text-decoration: none; transition: all 0.2s;
    }
    .pagination li a:hover { color: white; border-color: rgba(255,255,255,0.2); background: #1e293b; }
    .pagination li.active span {
      background: #2563eb; border-color: rgba(96,165,250,0.4);
      color: white; font-weight: 600;
      box-shadow: 0 0 12px rgba(37,99,235,0.4);
    }
    .pagination li.disabled span { color: rgba(255,255,255,0.2); border-color: rgba(255,255,255,0.05); cursor: not-allowed; }

    /* Symfony form errors */
    .form-error-message, ul.form-errors li {
      color: #f87171; font-size: 0.75rem; margin-top: 4px;
    }
  </style>

  {% block javascripts %}
    {{ encore_entry_script_tags('app') }}
  {% endblock %}
</head>
<body class="text-white antialiased">

  {% include 'layout/header.html.twig' %}

  {% block body %}{% endblock %}

</body>
</html>