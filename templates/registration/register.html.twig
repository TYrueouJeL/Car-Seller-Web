{% extends 'base.html.twig' %}
{% block title %}Création de compte{% endblock %}
{% block body %}

<div class="min-h-[calc(100vh-64px)] bg-slate-950 flex items-center justify-center px-6 py-14 relative">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_0%,rgba(37,99,235,0.12),transparent)] pointer-events-none"></div>

  <div class="w-full max-w-md relative">

    <!-- Header -->
    <div class="text-center mb-8">
      <span class="text-4xl">⬡</span>
      <h1 class="text-3xl font-black text-white tracking-tight mt-2">Créer un compte</h1>
      <p class="text-white/35 text-sm mt-2">Rejoignez CarSeller dès aujourd'hui</p>
    </div>

    <!-- Card -->
    <div class="bg-slate-900 border border-white/8 rounded-2xl p-8">

      {{ form_errors(registrationForm) }}

      {{ form_start(registrationForm, {
        'attr': {'class': 'flex flex-col gap-5', 'novalidate': 'novalidate'}
      }) }}

        <div class="grid grid-cols-2 gap-4">
          <div class="flex flex-col gap-1.5">
            {{ form_label(registrationForm.firstname, 'Prénom', {
              'label_attr': {'class': 'text-white/50 text-xs uppercase tracking-wider'}
            }) }}
            {{ form_widget(registrationForm.firstname, {
              'attr': {'class': 'w-full bg-slate-800 border border-white/10 text-white placeholder-white/20 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-blue-500/60 transition-colors'}
            }) }}
            {{ form_errors(registrationForm.firstname) }}
          </div>
          <div class="flex flex-col gap-1.5">
            {{ form_label(registrationForm.lastname, 'Nom', {
              'label_attr': {'class': 'text-white/50 text-xs uppercase tracking-wider'}
            }) }}
            {{ form_widget(registrationForm.lastname, {
              'attr': {'class': 'w-full bg-slate-800 border border-white/10 text-white placeholder-white/20 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-blue-500/60 transition-colors'}
            }) }}
            {{ form_errors(registrationForm.lastname) }}
          </div>
        </div>

        <div class="flex flex-col gap-1.5">
          {{ form_label(registrationForm.email, 'Adresse e-mail', {
            'label_attr': {'class': 'text-white/50 text-xs uppercase tracking-wider'}
          }) }}
          {{ form_widget(registrationForm.email, {
            'attr': {'class': 'w-full bg-slate-800 border border-white/10 text-white placeholder-white/20 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-blue-500/60 transition-colors'}
          }) }}
          {{ form_errors(registrationForm.email) }}
        </div>

        <div class="flex flex-col gap-1.5">
          {{ form_label(registrationForm.plainPassword, 'Mot de passe', {
            'label_attr': {'class': 'text-white/50 text-xs uppercase tracking-wider'}
          }) }}
          {{ form_widget(registrationForm.plainPassword, {
            'attr': {'class': 'w-full bg-slate-800 border border-white/10 text-white placeholder-white/20 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-blue-500/60 transition-colors'}
          }) }}
          {{ form_errors(registrationForm.plainPassword) }}
        </div>

        <button type="submit"
          class="w-full bg-blue-600 hover:bg-blue-500 text-white font-semibold py-3 rounded-xl transition-all duration-200 hover:-translate-y-0.5 shadow-[0_4px_16px_rgba(37,99,235,0.3)] mt-2">
          Créer le compte
        </button>

      {{ form_end(registrationForm) }}

    </div>

    <!-- Lien connexion -->
    <p class="text-center text-white/30 text-sm mt-6">
      Déjà un compte ?
      <a href="{{ path('app_login') }}" class="text-blue-400 hover:text-blue-300 transition-colors">Se connecter</a>
    </p>

  </div>
</div>

{% endblock %}