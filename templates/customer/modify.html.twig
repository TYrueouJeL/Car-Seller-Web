{% extends 'base.html.twig' %}
{% block title %}Modification de compte{% endblock %}
{% block body %}
<div class="min-h-[calc(100vh-64px)] bg-slate-950 px-6 py-14 relative">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_40%_at_50%_0%,rgba(37,99,235,0.09),transparent)] pointer-events-none"></div>

  <div class="max-w-5xl mx-auto relative flex flex-col gap-10">

    <!-- Header profil -->
    <div class="flex items-center gap-5 justify-between">
      <div class="flex items-center gap-4">
        <div class="shrink-0 w-14 h-14 rounded-xl bg-blue-600 flex items-center justify-center font-black text-white text-lg leading-none shadow-[0_0_20px_rgba(37,99,235,0.45)]">
          {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
        </div>
        <div>
          <p class="text-blue-400 text-xs font-semibold tracking-widest uppercase mb-0.5">Espace personnel</p>
          <h1 class="text-2xl font-black text-white tracking-tight leading-none">{{ app.user.firstName }} {{ app.user.lastName }}</h1>
          <p class="text-white/35 text-sm mt-1">{{ app.user.email }}</p>
        </div>
      </div>
      <a href="{{ path('app_customer') }}" class="inline-flex items-center gap-2 px-4 py-2 bg-slate-900 border border-white/8 rounded-lg text-sm text-white hover:bg-slate-800 transition-colors">
        Retour à mon compte
      </a>
    </div>

    <!-- Formulaire de modification -->
    <div class="bg-slate-900 border border-white/8 rounded-2xl p-6">
      <p class="text-white/35 text-xs uppercase tracking-widest mb-5">Modifier mes informations</p>
      {{ form_start(form) }}
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div>
            {{ form_label(form.lastname, 'Nom', {'label_attr': {'class': 'text-white/30 text-xs uppercase tracking-wider mb-1'}}) }}
            {{ form_widget(form.lastname, {'attr': {'class': 'w-full bg-slate-800 border border-white/8 rounded-lg px-3 py-2 text-sm text-white focus:ring-2 focus:ring-blue-500 focus:outline-none'}}) }}
          </div>
          <div>
            {{ form_label(form.firstname, 'Prénom', {'label_attr': {'class': 'text-white/30 text-xs uppercase tracking-wider mb-1'}}) }}
            {{ form_widget(form.firstname, {'attr': {'class': 'w-full bg-slate-800 border border-white/8 rounded-lg px-3 py-2 text-sm text-white focus:ring-2 focus:ring-blue-500 focus:outline-none'}}) }}
          </div>
          <div>
            {{ form_label(form.email, 'Adresse e-mail', {'label_attr': {'class': 'text-white/30 text-xs uppercase tracking-wider mb-1'}}) }}
            {{ form_widget(form.email, {'attr': {'class': 'w-full bg-slate-800 border border-white/8 rounded-lg px-3 py-2 text-sm text-white focus:ring-2 focus:ring-blue-500 focus:outline-none'}}) }}
          </div>
        </div>
        <div class="mt-6">
          <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 border border-transparent rounded-lg text-sm text-white hover:bg-blue-700 transition-colors">
            Enregistrer les modifications
          </button>
        </div>
      {{ form_end(form) }}
    </div>
{% endblock %}