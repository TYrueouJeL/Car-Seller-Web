{# ticket/index.html.twig #}
{% extends 'base.html.twig' %}
{% block title %}Mes tickets{% endblock %}
{% block body %}

<div class="min-h-[calc(100vh-64px)] bg-slate-950 px-6 py-14 relative">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_40%_at_50%_0%,rgba(37,99,235,0.1),transparent)] pointer-events-none"></div>

  <div class="max-w-4xl mx-auto relative">

    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-10">
      <div>
        <p class="text-blue-400 text-xs font-semibold tracking-widest uppercase mb-1">Support</p>
        <h1 class="text-4xl font-black text-white tracking-tight">Mes tickets</h1>
      </div>
      <a href="{{ path('app_ticket_new') }}"
        class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-semibold px-5 py-2.5 rounded-xl transition-all duration-200 hover:-translate-y-0.5 shadow-[0_4px_16px_rgba(37,99,235,0.3)] text-sm whitespace-nowrap">
        + Créer un ticket
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {% for ticket in tickets %}
        <a href="{{ path('app_ticket_detail', {'id': ticket.id}) }}"
          class="group bg-slate-900 border border-white/8 rounded-2xl p-6 flex flex-col gap-3 hover:border-blue-500/40 hover:-translate-y-1 transition-all duration-300 no-underline">
          <div class="flex items-start justify-between gap-3">
            <h3 class="text-white font-bold text-base leading-tight">{{ ticket.title }}</h3>
            <span class="shrink-0 text-xs font-semibold px-2.5 py-1 rounded-full
              {% if ticket.status.name == 'Résolu' %}text-emerald-400 bg-emerald-500/10 border border-emerald-500/20
              {% elseif ticket.status.name == 'En cours' %}text-yellow-400 bg-yellow-500/10 border border-yellow-500/20
              {% else %}text-blue-400 bg-blue-500/10 border border-blue-500/20{% endif %}">
              {{ ticket.status.name }}
            </span>
          </div>
          <p class="text-white/45 text-sm leading-relaxed line-clamp-2">{{ ticket.description }}</p>
          <div class="flex items-center justify-between mt-auto pt-3 border-t border-white/6">
            <span class="text-white/25 text-xs">#{{ ticket.id }}</span>
            <span class="text-white/25 text-xs">{{ ticket.createdAt|date('d/m/Y H:i') }}</span>
          </div>
        </a>
      {% else %}
        <p class="col-span-2 text-center text-white/30 italic py-16">Vous n'avez pas encore de tickets.</p>
      {% endfor %}
    </div>

  </div>
</div>

{% endblock %}