{% extends 'base.html.twig' %}

{% block title %}Ticket{% endblock %}

{% block body %}
    <div class="container mx-auto px-8 py-8">
        <h1 class="title text-center">Page d'aide</h1>

        <div class="mt-10">
            <div class="flex justify-center gap-2 items-center mb-4">
                <h2 class="text-2xl font-bold cols-span-2">Vos tickets</h2>
                <a href="{{ path('app_ticket_new') }}" class="card-button w-fit">Créer un ticket</a>
            </div>


            <div class="grid grid-cols-2 gap-6 mb-4">
                {% for ticket in tickets %}
                    <a href="{{ path('app_ticket_detail', {'id': ticket.id}) }}" class="card mb-4">
                        <h3 class="text-lg font-semibold mb-2">Ticket #{{ ticket.id }} - {{ ticket.title }}</h3>
                        <p class="mb-2">{{ ticket.description }}</p>
                        <p class="text-sm text-gray-600">Statut: {{ ticket.status.name }}</p>
                        <p class="text-sm text-gray-600">Créé le: {{ ticket.createdAt|date('d/m/Y H:i') }}</p>
                    </a>
                {% else %}
                    <p class="text-center col-span-2">Vous n'avez pas encore de tickets.</p>
                {% endfor %}
            </div>
        </div>
    </div>
{% endblock %}
