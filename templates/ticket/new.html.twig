{% extends 'base.html.twig' %}

{% block title %}Créer un ticket{% endblock %}

{% block body %}
    <div class="container mx-auto px-8 py-8">
        <h1 class="title text-center">Créer un ticket</h1>

        {{ form_start(form) }}
            <div class="mb-6">
                {{ form_label(form.title) }}
                {{ form_widget(form.title, {'attr': {'class': 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
                {{ form_errors(form.title) }}
            </div>

            <div class="mb-6">
                {{ form_label(form.description) }}
                {{ form_widget(form.description, {'attr': {'class': 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 h-32'}}) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="flex gap-4 justify-center">
                <button type="submit" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-lg transition duration-200">
                    Créer le ticket
                </button>
                <a href="{{ path('app_ticket') }}" class="bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-6 rounded-lg transition duration-200">
                    Annuler
                </a>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
