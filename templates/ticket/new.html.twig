{# ticket/new.html.twig #}
{% extends 'base.html.twig' %}
{% block title %}Créer un ticket{% endblock %}
{% block body %}

<div class="min-h-[calc(100vh-64px)] bg-slate-950 flex items-center justify-center px-6 py-14 relative">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_0%,rgba(37,99,235,0.1),transparent)] pointer-events-none"></div>

  <div class="w-full max-w-lg relative">

    <div class="text-center mb-8">
      <p class="text-blue-400 text-xs font-semibold tracking-widest uppercase mb-2">Support</p>
      <h1 class="text-3xl font-black text-white tracking-tight">Créer un ticket</h1>
      <p class="text-white/35 text-sm mt-2">Décrivez votre problème, nous vous répondrons rapidement.</p>
    </div>

    <div class="bg-slate-900 border border-white/8 rounded-2xl p-8">
      {{ form_start(form, {'attr': {'class': 'flex flex-col gap-5'}}) }}

        <div class="flex flex-col gap-1.5">
          {{ form_label(form.title, 'Titre', {'label_attr': {'class': 'text-white/50 text-xs uppercase tracking-wider'}}) }}
          {{ form_widget(form.title, {'attr': {'class': 'w-full bg-slate-800 border border-white/10 text-white placeholder-white/20 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-blue-500/60 transition-colors'}}) }}
          {{ form_errors(form.title) }}
        </div>

        <div class="flex flex-col gap-1.5">
          {{ form_label(form.description, 'Description', {'label_attr': {'class': 'text-white/50 text-xs uppercase tracking-wider'}}) }}
          {{ form_widget(form.description, {'attr': {'class': 'w-full bg-slate-800 border border-white/10 text-white placeholder-white/20 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-blue-500/60 transition-colors h-32 resize-none'}}) }}
          {{ form_errors(form.description) }}
        </div>

        <div class="flex gap-3 mt-2">
          <button type="submit"
            class="flex-1 bg-blue-600 hover:bg-blue-500 text-white font-semibold py-3 rounded-xl transition-all duration-200 hover:-translate-y-0.5 shadow-[0_4px_16px_rgba(37,99,235,0.3)]">
            Créer le ticket
          </button>
          <a href="{{ path('app_ticket') }}"
            class="flex-1 bg-slate-800 hover:bg-slate-700 border border-white/10 text-white/60 hover:text-white text-center font-semibold py-3 rounded-xl transition-all duration-200 text-sm">
            Annuler
          </a>
        </div>

      {{ form_end(form) }}
    </div>

  </div>
</div>

{% endblock %}